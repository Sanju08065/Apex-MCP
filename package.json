{
  "name": "apex",
  "version": "1.0.0",
  "publisher": "apex",
  "engines": {
    "vscode": "^1.85.0"
  },
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "apex-mcp.startAgent",
        "title": "Start Agent",
        "icon": "$(play)",
        "category": "Apex MCP"
      },
      {
        "command": "apex-mcp.pauseAgent",
        "title": "Pause Agent",
        "icon": "$(debug-pause)",
        "category": "Apex MCP"
      },
      {
        "command": "apex-mcp.stopAgent",
        "title": "Stop Agent",
        "icon": "$(stop)",
        "category": "Apex MCP"
      },
      {
        "command": "apex-mcp.killSwitch",
        "title": "Emergency Kill Switch",
        "icon": "$(error)",
        "category": "Apex MCP"
      },
      {
        "command": "apex-mcp.toggleReadOnlyMode",
        "title": "Toggle Read-Only Analysis Mode",
        "icon": "$(eye)",
        "category": "Apex MCP"
      },
      {
        "command": "apex-mcp.viewSessionHistory",
        "title": "View Session History",
        "icon": "$(history)",
        "category": "Apex MCP"
      },
      {
        "command": "apex-mcp.rollbackLastAction",
        "title": "Rollback Last Action",
        "icon": "$(discard)",
        "category": "Apex MCP"
      },
      {
        "command": "apex-mcp.startMcpServer",
        "title": "Start MCP Server in Terminal",
        "icon": "$(terminal)",
        "category": "Apex MCP"
      },
      {
        "command": "apex-mcp.showLicense",
        "title": "Manage License",
        "icon": "$(key)",
        "category": "Apex MCP"
      },
      {
        "command": "apex-mcp.checkLicense",
        "title": "Check License Status",
        "icon": "$(shield)",
        "category": "Apex MCP"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "apex-mcp-container",
          "title": "Apex MCP Agent",
          "icon": "$(robot)"
        }
      ]
    },
    "views": {
      "apex-mcp-container": [
        {
          "id": "apex-mcp.agentControl",
          "name": "Agent Control",
          "type": "webview"
        },
        {
          "id": "apex-mcp.actionHistory",
          "name": "Action History"
        },
        {
          "id": "apex-mcp.sessionMemory",
          "name": "Session Memory"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "apex-mcp.startAgent",
          "when": "view == apex-mcp.agentControl",
          "group": "navigation@1"
        },
        {
          "command": "apex-mcp.pauseAgent",
          "when": "view == apex-mcp.agentControl",
          "group": "navigation@2"
        },
        {
          "command": "apex-mcp.stopAgent",
          "when": "view == apex-mcp.agentControl",
          "group": "navigation@3"
        },
        {
          "command": "apex-mcp.killSwitch",
          "when": "view == apex-mcp.agentControl",
          "group": "navigation@4"
        }
      ]
    },
    "configuration": {
      "title": "Apex MCP Agent",
      "properties": {
        "apex-mcp.maxStepsPerSession": {
          "type": "number",
          "default": 100,
          "description": "Maximum number of steps allowed per agent session"
        },
        "apex-mcp.maxToolCallsPerStep": {
          "type": "number",
          "default": 10,
          "description": "Maximum tool calls allowed per step"
        },
        "apex-mcp.failureLoopThreshold": {
          "type": "number",
          "default": 3,
          "description": "Number of consecutive failures before halting"
        },
        "apex-mcp.confirmDestructiveActions": {
          "type": "boolean",
          "default": true,
          "description": "Require user confirmation for destructive actions"
        },
        "apex-mcp.blockedPaths": {
          "type": "array",
          "default": [
            ".git",
            ".env",
            ".secret",
            "node_modules"
          ],
          "description": "Path patterns blocked from agent access"
        },
        "apex-mcp.mcpServerPort": {
          "type": "number",
          "default": 0,
          "description": "MCP server port (0 for auto-assign via stdio)"
        },
        "apex-mcp.readOnlyMode": {
          "type": "boolean",
          "default": false,
          "description": "Enable read-only analysis mode (no writes)"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./ && node -e \"require('fs').copyFileSync('out/extension-stub.js', 'out/extension.js')\"",
    "watch": "tsc -watch -p ./",
    "build": "cross-env NODE_ENV=production node build.config.js",
    "aliases": "node scripts/generate-rotating-aliases.js",
    "zip": "node scripts/create-protected-zip.js",
    "encrypt-all": "node scripts/encrypt-all-files.js",
    "package": "npm run build && npm run aliases && npm run zip && vsce package --no-dependencies --allow-missing-repository",
    "package-encrypted": "node scripts/build-encrypted-vsix.js",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.85.0",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vscode/vsce": "^2.22.0",
    "archiver": "^7.0.1",
    "archiver-zip-encrypted": "^2.0.0",
    "cross-env": "^7.0.3",
    "esbuild": "^0.19.0",
    "eslint": "^8.0.0",
    "javascript-obfuscator": "^4.2.2",
    "node-7z-archive": "^1.1.7",
    "typescript": "^5.3.0",
    "yazl": "^3.3.1"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.20.9",
    "@modelcontextprotocol/sdk": "^1.25.3",
    "adm-zip": "^0.5.16",
    "cors": "^2.8.6",
    "diff": "^5.2.0",
    "dotenv": "^17.2.3",
    "firebase-admin": "^13.6.0",
    "ws": "^8.16.0"
  }
}
